{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-5",
  "instructions": [
    "./AGENTS.md"
  ],
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git commit": "allow",
      "git push": "ask",
      "npm *": "allow",
      "rm *": "deny"
    },
    "read": "allow",
    "edit": "ask"
  }
}