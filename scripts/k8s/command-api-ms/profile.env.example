# Archivo de ejemplo para variables de entorno
# Copiar este archivo y renombrar a dev.env, staging.env, prod.env según el perfil requerido

# ============================================
# Configuración HTTP
# ============================================
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ============================================
# CORS Configuration
# ============================================
# Habilitar CORS (default: true)
CORS_ENABLED=true
# Origins permitidos separados por coma (ej: http://localhost:3000,http://localhost:3001)
CORS_ORIGINS=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=command_db
DB_USER=factoria
DB_PASSWORD=change_me_profile!

# Deployment Configuration
IMAGE_REGISTRY_SERVER=registry.cmaconsulting.org
IMAGE_VERSION=command-api-ms:1.0.0
IMAGE_REGISTRY_SECRET=change_me_profile!

# K8s Configuration
KUBECTL_CONTEXT=local
K8S_NAMESPACE=synopsis-ws