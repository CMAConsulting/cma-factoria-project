# PostgreSQL Configuration Example
# Copiar a dev.env, staging.env, prod.env y ajustar valores

# ===== Profile =====
ENV_PROFILE=dev

# ===== PostgreSQL Settings =====
ENV_POSTGRES_VERSION=16
ENV_POSTGRES_PORT=5432
ENV_POSTGRES_DB=factoria
ENV_POSTGRES_USER=factoria
ENV_POSTGRES_PASSWORD=change_me_in_production

# ===== Storage =====
# true = native Docker volume, false = bind mount to .tmp
ENV_USE_NATIVE_VOLUME=false
ENV_VOLUMEN_PATH=/opt/docker/volumes/postgres/dev/data