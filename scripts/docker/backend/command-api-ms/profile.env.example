# Archivo de ejemplo para variables de entorno
# Copiar este archivo y renombrar a dev.env, staging.env, prod.env según el perfil requerido
# Variables requeridas para conexión a PostgreSQL para impactar scripts de dashboard-db

# Configuración HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=*

# Database Configuration
DB_HOST=192.168.18.7
DB_PORT=5432
DB_NAME=command_db
DB_USER=factoria
DB_PASSWORD=change_me_profile!

# Configuracion para build.sh
ENV_IMAGE_NAME=command-api-ms
ENV_TAG=1.0.0

# Configuracion para Image Registry
ENV_REGISTRY_SERVER=registry.cmaconsulting.org
ENV_REGISTRY_USERNAME=elperez
ENV_REGISTRY_PASSWORD=change_me_profile!